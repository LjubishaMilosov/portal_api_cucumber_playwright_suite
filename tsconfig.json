{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "features/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}